{
  "name": "storage-toggler",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "dev:preview": "vite dev --open /dev.html",
    "build": "tsc && vite build",
